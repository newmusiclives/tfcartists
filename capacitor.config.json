{
  "appId": "com.truefans.radio",
  "appName": "TrueFans RADIO",
  "webDir": "out",
  "server": {
    "url": "https://truefans-radio.netlify.app",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#78350f",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#78350f"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
    "scheme": "TrueFans RADIO",
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#78350f"
  }
}
