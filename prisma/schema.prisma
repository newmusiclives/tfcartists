// =============================================================================
// NEWSLETTER
// =============================================================================

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  email         String
  name          String?

  // Organization scoping
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Preferences
  weeklyDigest      Boolean @default(true)
  artistSpotlight   Boolean @default(true)
  newMusicAlerts    Boolean @default(true)
  stationUpdates    Boolean @default(true)

  // Status
  isActive      Boolean  @default(true)
  confirmedAt   DateTime?
  unsubscribedAt DateTime?
  unsubscribeToken String @unique @default(cuid())

  // Linked listener (if registered)
  listenerId    String?

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([isActive])
}

model NewsletterEdition {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Content
  type          String   // "weekly_digest" | "artist_spotlight" | "new_music" | "custom"
  subject       String
  htmlContent   String   @db.Text
  textContent   String   @db.Text

  // Delivery stats
  sentAt        DateTime?
  recipientCount Int     @default(0)
  openCount     Int      @default(0)
  clickCount    Int      @default(0)

  @@index([organizationId])
  @@index([type])
}

// =============================================================================
// WEBHOOK ENDPOINTS & DELIVERY LOG
// =============================================================================
// Operator-scoped webhook endpoints for Zapier / Make / custom integrations.
model WebhookEndpoint {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name           String            // Human-readable label, e.g. "Zapier Song Alerts"
  url            String            // Target URL (https://hooks.zapier.com/...)
  secret         String            // HMAC-SHA256 signing secret
  events         String[]          // Subscribed event types, e.g. ["track.played","artist.created"]
  active         Boolean  @default(true)

  deliveries     WebhookDelivery[]

  @@index([organizationId])
  @@index([active])
}

// Individual delivery attempt for auditing & debugging.
model WebhookDelivery {
  id          String   @id @default(cuid())
  deliveredAt DateTime @default(now())

  endpointId  String
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  event       String            // e.g. "artist.created"
  payload     Json              // Full payload sent
  statusCode  Int?              // HTTP response status (null if network error)
  response    String?           // First 1 KB of response body
  success     Boolean @default(false)
  error       String?           // Error message if failed
  duration    Int?              // Round-trip time in ms

  @@index([endpointId])
  @@index([event])
  @@index([deliveredAt])
}
