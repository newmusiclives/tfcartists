    "@sentry/browser": "^10.43.0",
    "@types/web-push": "^3.6.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^4.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.33",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^4.69.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.14.0",
