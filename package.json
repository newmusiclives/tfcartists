{
  "name": "tfcartists-riley",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prebuild-slim.js && prisma generate && next build && node scripts/postbuild-restore.js",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "voice-tracks": "tsx scripts/run-voice-tracks.ts --direct",
    "voice-tracks:api": "tsx scripts/run-voice-tracks.ts",
    "fix-ads": "tsx scripts/fix-sponsor-ads.ts",
    "generate-playlists": "tsx scripts/generate-today-playlists.ts",
    "fix-clocks": "tsx scripts/fix-clock-show-openings.ts",
    "db:seed": "tsx scripts/seed-all-teams.ts",
    "db:seed:demo": "tsx scripts/seed-demo-data.ts",
    "setup": "npm install && npx prisma db push && npm run db:seed",
    "migrate:r2": "tsx scripts/migrate-audio-to-r2.ts",
    "migrate:r2:dry": "tsx scripts/migrate-audio-to-r2.ts --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
