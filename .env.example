# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# For Development: SQLite (simple file-based database)
# For Production: PostgreSQL URL from your database provider (Supabase, Neon, Railway, etc.)
DATABASE_URL="file:./dev.db"

# Example PostgreSQL URLs:
# DATABASE_URL="postgresql://user:password@host:port/database"
# DATABASE_URL="postgresql://user:password@db.supabase.co:5432/postgres"

# =============================================================================
# AI PROVIDERS (at least one required)
# =============================================================================

# OpenAI API Key - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-key-here"

# Anthropic (Claude) API Key - Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key-here"

# Default AI provider to use ("openai" or "claude")
DEFAULT_AI_PROVIDER="claude"

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================

# NextAuth URL - Set to your production URL in production
NEXTAUTH_URL="http://localhost:3000"

# NextAuth Secret - Generate with: openssl rand -base64 32
# IMPORTANT: Generate a new secret for production!
NEXTAUTH_SECRET="generate-a-secret-for-production"

# =============================================================================
# TEAM PASSWORDS (Optional - defaults provided in code)
# =============================================================================

ADMIN_PASSWORD="truefans2024"
RILEY_PASSWORD="riley2024"
HARPER_PASSWORD="harper2024"
ELLIOT_PASSWORD="elliot2024"
CASSIDY_PASSWORD="cassidy2024"

# =============================================================================
# MESSAGE DELIVERY SERVICES (Optional - for sending messages to artists/sponsors)
# =============================================================================

# GoHighLevel (SMS + Email) - Get from: https://app.gohighlevel.com/
GHL_API_KEY=""
GHL_LOCATION_ID=""
GHL_RILEY_PIPELINE_ID=""
GHL_CASSIDY_PIPELINE_ID=""
GHL_HARPER_PIPELINE_ID=""
GHL_ELLIOT_PIPELINE_ID=""

# Instagram (Direct Messages) - Requires Instagram Business Account + Graph API access
INSTAGRAM_ACCESS_TOKEN=""

# =============================================================================
# OBJECT STORAGE (Cloudflare R2)
# =============================================================================

# R2 credentials — create an API token at:
# https://dash.cloudflare.com/ → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="truefans-assets"

# Public URL for serving assets (custom domain or R2.dev URL)
# Example: https://assets.yourdomain.com
R2_PUBLIC_URL=""

# =============================================================================
# PAYMENTS & PAYOUTS (Manifest Financial)
# =============================================================================

# Manifest Financial - Get from: https://manifest.fin
MANIFEST_API_KEY=""
MANIFEST_WEBHOOK_SECRET=""

# =============================================================================
# SOCIAL MEDIA DISCOVERY
# =============================================================================

# TikTok API - For discovering artists on TikTok
TIKTOK_API_KEY=""

# Spotify API - For discovering artists on Spotify
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# =============================================================================
# VOICE AI (Harper's Phone Calls)
# =============================================================================

# Vapi AI - For automated sales calls
VAPI_API_KEY=""
VAPI_PHONE_NUMBER=""

# =============================================================================
# AUTOMATION & CRON JOBS
# =============================================================================

# Cron Secret - Generate with: openssl rand -base64 32
# Used to authenticate cron job requests
CRON_SECRET="generate-a-secret-for-production"

# =============================================================================
# RATE LIMITING (Optional - uses in-memory limits in development)
# =============================================================================

# Upstash Redis - Get from: https://console.upstash.com/
# Required for production rate limiting across multiple instances
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# ERROR MONITORING
# =============================================================================

# Sentry DSN - Get from: https://sentry.io
SENTRY_DSN=""

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Enable/disable Riley's automated outreach
RILEY_ACTIVE="true"

# Maximum number of outreach messages Riley can send per day
RILEY_MAX_OUTREACH_PER_DAY="50"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Comma-separated list of allowed origins for CORS (in addition to NEXTAUTH_URL)
# Example: ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"
ALLOWED_ORIGINS=""

# =============================================================================
# STREAMING & RAILWAY BACKEND
# =============================================================================

# Railway backend URL (playout engine)
RAILWAY_BACKEND_URL="https://tfc-radio-backend-production.up.railway.app"

# Public stream URL for embed player
NEXT_PUBLIC_STREAM_URL="https://tfc-radio.netlify.app/stream/americana-hq.mp3"

# Station name for now-playing endpoint
NOW_PLAYING_URL=""

# =============================================================================
# VOICE AI (Google Gemini TTS — alternative to ElevenLabs)
# =============================================================================

# Google AI API Key — used for Gemini TTS voice generation
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=""

# =============================================================================
# VOICE TRACK GENERATION
# =============================================================================

# When true, voice tracks use generic mood talk instead of referencing song titles.
# Set to true if Railway is NOT consuming /api/playout/hour (prevents wrong-song references).
# Default: false (DJs reference actual song titles from locked playlists)
VOICE_TRACK_SAFE_MODE="false"

# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL=""

# =============================================================================
# ALERTING
# =============================================================================

# Webhook URL for cron failure alerts (Slack/Discord incoming webhook)
CRON_ALERT_WEBHOOK_URL=""

# =============================================================================
# STATION BRANDING (Public — exposed to client)
# =============================================================================

# These configure the station identity for the public-facing site.
# All are optional — defaults are pulled from the database Station record.
NEXT_PUBLIC_STATION_NAME=""
NEXT_PUBLIC_STATION_CALL_SIGN=""
NEXT_PUBLIC_STATION_TAGLINE=""
NEXT_PUBLIC_STATION_GENRE=""
NEXT_PUBLIC_STATION_CODE=""
NEXT_PUBLIC_SITE_URL=""
NEXT_PUBLIC_SITE_DESCRIPTION=""
NEXT_PUBLIC_PRIMARY_COLOR=""
NEXT_PUBLIC_SECONDARY_COLOR=""
NEXT_PUBLIC_FORMAT_TYPE=""
NEXT_PUBLIC_NETWORK_NAME=""

# =============================================================================
# GOHIGHLEVEL CHAT WIDGET & TRACKING
# =============================================================================

# GHL Chat Widget ID — from GHL > Sites > Chat Widget > Install Code
# Enables live support chat on all pages
NEXT_PUBLIC_GHL_WIDGET_ID=""

# GHL Tracking ID — from GHL > Settings > Business Info > Tracking Code
# Enables visitor tracking, form analytics, and attribution
NEXT_PUBLIC_GHL_TRACKING_ID=""

# =============================================================================
# ANALYTICS (fallback if not using GHL tracking)
# =============================================================================

# Google Analytics Measurement ID — from GA4 > Admin > Data Streams
# Only used if GHL tracking is not configured
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# =============================================================================
# IMPORTANT NOTES
# =============================================================================

# DO NOT set NODE_ENV manually - Next.js sets it automatically
# Setting NODE_ENV manually will cause build issues

# For Vercel deployment, set all required variables in:
# Project settings → Environment variables

# For Netlify deployment, set all required variables in:
# Site settings → Environment variables

# Minimum required for basic functionality:
# - DATABASE_URL (PostgreSQL in production)
# - ANTHROPIC_API_KEY or OPENAI_API_KEY
# - NEXTAUTH_SECRET (generate a secure random string)
# - NEXTAUTH_URL (your production URL)

# For Netlify scheduled functions (cron jobs):
# - Requires Netlify Pro plan or higher
# - CRON_SECRET (generate a secure random string)

# Auto-set by platforms (do NOT set manually):
# - NETLIFY (set by Netlify)
# - URL (set by Netlify — your site URL)
# - VERCEL_URL (set by Vercel)
